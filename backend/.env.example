# ============================================
# 校园帮 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# --- 数据库 ---
DB_PASSWORD=your_db_password

# --- JWT ---
JWT_SECRET=your_jwt_secret_at_least_256_bits
JWT_EXPIRATION=604800000

# --- 微信小程序 ---
WECHAT_APPID=wx491e4b37ff5d0130
WECHAT_SECRET=your_wechat_app_secret

# --- 支付宝（沙箱环境） ---
ALIPAY_APP_ID=9021000164657830
ALIPAY_PRIVATE_KEY=your_alipay_app_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=http://localhost:8080/api/pay/alipay/notify

# --- CORS ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- 腾讯地图 ---
MAP_TENCENT_KEY=your_tencent_map_key

# --- 百度 OCR ---
BAIDU_OCR_APP_ID=your_baidu_ocr_app_id
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key
